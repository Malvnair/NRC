"""
Open a DIFFEXP or fk image, read the matching plantList, choose a random/most mag fake KBO,
cut out a small image around it, and display/save the result.

"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from astropy.io import fits
from pathlib import Path
import sys

FITS_FILE = input("Enter FITS file: ")
CCD = input("Enter CCD number (def=15): ")
HALF_SIZE = input("Enter cutout size (def=50): ")

if HALF_SIZE == "":
    HALF_SIZE = 50
else:
    HALF_SIZE = int(HALF_SIZE)

if CCD == "":
    CCD = 15
else:
    CCD = int(CCD)

if FITS_FILE == "":
    FITS_FILE = "/arc/projects/classy/dbimages/2773118/fk2773118p.fits"




#########
# automatically generate the plantList path from the FITS file + CCD
fits_path = Path(FITS_FILE)

name = fits_path.stem

if name.startswith("DIFFEXP"):
    # DIFFEXP-2773082-2773118-15.fits
    parts = name.split("-")

    image_id = parts[1]
    ref_id = parts[2]

    # use CCD from filename
    CCD = int(parts[3])

    PLANT_FILE = (
        fits_path.parent /
        f"{image_id}p{CCD}-{ref_id}p{CCD}.plantList"
    )

else:
    # fk2773118p.fits or 2773118p.fits
    image_id = name.replace("fk", "").replace("p", "")

    PLANT_FILE = (
        fits_path.parent /
        f"ccd{CCD}" /
        f"{image_id}p{CCD}.plantList"
    )




#########
# open the fits file and read the image and header
if not fits_path.exists():
    sys.exit("FITS file not found.")

with fits.open(fits_path) as hdul:
    #hdul.info()
    #print()

    # DIFFEXP files have image data in HDU 1
    # fk dbimages have image data in HDU 0
    # full fk mosaic files have PRIMARY in HDU 0, so CCD 15 is HDU 16
    # non-fk dbimage mosaic files are handled the same as fk mosaic files
    #  loop fiinds the first HDU that actually contains image datas
    image = None
    header = None
    hdu_used = None 

    name = Path(FITS_FILE).stem

    if name.startswith("DIFFEXP"):
        # DIFFEXP-2773082-2773118-15.fits
        # DIFFEXP image data is usually in HDU 1
        hdu_used = 1

        image = hdul[hdu_used].data
        header = hdul[hdu_used].header

    else:
        # fk2773118p.fits or 2773118p.fits is a full mosaic file

        # proper index!!!
        # if HDU 0 is PRIMARY, then CCD 15 is HDU 16
        hdu_used = CCD + 1

        image = hdul[hdu_used].data
        header = hdul[hdu_used].header

    if image is None:
        sys.exit("No image data found")

    image = image.astype(np.float32)
    
height, width = image.shape

print(f"\nUsing:")
print(f"FITS_FILE  = {FITS_FILE}")
print(f"CCD        = {CCD}")
print(f"HDU        = {hdu_used}")
print(f"PLANT_FILE = {PLANT_FILE}")
print(f"Image shape: {image.shape}")


# read the plant list
plant_path = Path(PLANT_FILE)
if not plant_path.exists():
    sys.exit("Plant list not found")

col_names = [
    'index', 'ra', 'dec', 'x', 'y',
    'rate', 'angle', 'rate_ra', 'rate_dec',
    'mag', 'psf_amp', 'g_i'
]

df = pd.read_csv(
    plant_path,
    sep=r'\s+',
    comment='#',
    names=col_names,
    dtype=float,
)

print(f"Planted objects total: {len(df)}")


# filter only objects that allow a full cutout
H = HALF_SIZE

# cutout of size 2*H x 2*H must fit inside the image,
# so the centre must be at least H pixels from each edge
safe = df[
    (df['x'] >= H) & (df['x'] < width  - H) &
    (df['y'] >= H) & (df['y'] < height - H)
].copy()

# learn manual arrays

print(f"Objects inside border (half-size={H}): {len(safe)}")

if safe.empty:
    sys.exit("No objects are inside the image")


# choose the brightest/low mag object
# near observing limit, 22, 23, 24, 25
# different motions, distributed across ccds
safe_sorted = safe.sort_values('mag')          # ascending = brightest first
row = safe_sorted.iloc[0]

# choose a random object
#row = safe.sample(n=1).iloc[0]


# print selected object info
obj_index = int(row['index'])
obj_x = row['x']
obj_y = row['y']
obj_mag = row['mag']
obj_rate = row['rate']
obj_angle = row['angle']
obj_rra = row['rate_ra']
obj_rdec = row['rate_dec']
obj_amp = row['psf_amp']

print("\nSelected object:")
print(f"index = {obj_index}")
print(f"x, y = {obj_x:.2f}, {obj_y:.2f}")
print(f"mag = {obj_mag:.2f}")
print(f"rate = {obj_rate:.2f} arcsec/hr, angle = {obj_angle:.2f} deg")
print(f"rate_ra = {obj_rra:.2f}  rate_dec = {obj_rdec:.2f} arcsec/hr")
print(f"psf_amp = {obj_amp:.5f}\n")


# image[y_row, x_col]
# integer pixel at the object centre
cx = int(round(obj_x))   # column x
cy = int(round(obj_y))   # row y

# extract cutout
cutout = image[
    cy - H : cy + H,
    cx - H : cx + H
].copy()

print(f"Cutout shape: {cutout.shape} centred at pixel ({cx}, {cy})")


#cutout[np.where((np.isnan(cutout))& (np.isinf(cutout)) = np.nanmedian(cutout)

# display cutout, take only valid pixels
finite_cut = cutout[np.isfinite(cutout)]
if finite_cut.size == 0:
    sys.exit("The cutout is NaN.")



# grayscale mapping
vmin = np.percentile(finite_cut, 1)
vmax = np.percentile(finite_cut, 99)


# PLOTTT
fig, ax = plt.subplots(figsize=(6, 6))

im = ax.imshow(
    cutout,
    origin='lower',
    cmap='gray',
    vmin=vmin,
    vmax=vmax,
)

plt.colorbar(im, ax=ax, label='Pixel Value (ADU)')


# mark where the fake object is supposed to be
ax.plot(
    H, H,
    '+',
    color='red',
    markersize=14,
    markeredgewidth=2,
    label=f'Planted Obj (mag={obj_mag:.2f})'
)

ax.set_xlabel('x')
ax.set_ylabel('y')

if name.startswith("fk"):
    image_type = "FK DBIMAGE"
else:
    image_type = "DBIMAGE"


# just getting the file IDs and CCD from the filename for the title
name = Path(FITS_FILE).stem

if name.startswith("DIFFEXP"):
    # DIFFEXP-2773082-2773118-15.fits
    parts = name.split("-")

    image_type = "DIFFEXP"
    image_id = parts[1]
    ref_id = parts[2]
    ccd_id = parts[3]

    # title with info from file
    title = (
        f"DIFFEXP {image_id}-{ref_id} | CCD {ccd_id} | Object {obj_index}\n"
        f"x={obj_x:.1f}  y={obj_y:.1f}  "
        f"Rate={obj_rate:.2f}\"/hr  Angle={obj_angle:.1f}°"
    )

    outfile = f"DIFFEXP_{image_id}_{ref_id}_CCD{ccd_id}_OBJ{obj_index}.png"

else:
    # fk2773118p.fits or 2773118p.fits
    image_id = name.replace("fk", "").replace("p", "")
    ccd_id = str(hdu_used - 1)

    title = (
        f"{image_type} {image_id} | CCD {ccd_id} | HDU {hdu_used} | Object {obj_index}\n"
        f"x={obj_x:.1f}  y={obj_y:.1f}  "
        f"Rate={obj_rate:.2f}\"/hr  Angle={obj_angle:.1f}°"
    )

    outfile = f"DBIMAGE_{image_id}_CCD{ccd_id}_HDU{hdu_used}_OBJ{obj_index}.png"


ax.set_title(title)
ax.legend(loc='upper right', fontsize=8)

plt.tight_layout()

plt.savefig(outfile, dpi=150)
plt.show()

print(f"Saved: {outfile}")



